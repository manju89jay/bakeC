 * {{ model.description | default("") | wordwrap(72) }}
 *
 * Generated by bakeC v{{ meta.generator_version }}
 * Model:    {{ meta.model_path }} [sha256:{{ meta.model_hash }}]
 * Platform: {{ meta.platform_path }} [sha256:{{ meta.platform_hash }}]
 * Date:     {{ meta.timestamp }}
 *
 * DO NOT EDIT — generated file. Modify model or templates instead.
 */

#include "{{ name }}_controller.h"
{% if platform.constraints.assertions %}
#include <assert.h>
{% endif %}

/* --- External data declarations --- */
{% for block in blocks %}
{% if block.type == "basis_function_sum" %}
extern const real_T {{ name }}_{{ block.name }}_coeffs[];
extern const real_T {{ name }}_{{ block.name }}_knots[];
{% elif block.type == "lookup_table" %}
extern const real_T {{ name }}_{{ block.name }}_bp[];
extern const real_T {{ name }}_{{ block.name }}_td[];
{% endif %}
{% endfor %}

/* --- Model I/O and state --- */
{{ name }}_ExtU_T {{ name }}_U;
{{ name }}_ExtY_T {{ name }}_Y;

{% for s in model.state %}
static real_T {{ name }}_{{ s.name }} = {{ s.initial_value }}{{ type_suffix }};
{% endfor %}

/* --- Block implementations --- */

{% for block in blocks %}
{% if block.type == "basis_function_sum" %}
{% include "blocks/basis_function.c.j2" %}
{% elif block.type == "pid" %}
{% include "blocks/pid.c.j2" %}
{% elif block.type == "lookup_table" %}
{% include "blocks/lookup_table.c.j2" %}
{% endif %}

{% endfor %}

/**
 * @brief Initialize the {{ name }} controller.
 *
 * @trace {{ meta.model_path }} → model (initialization)
 */
void {{ init_function }}(void)
{
{% for inp in model.inputs %}
    {{ name }}_U.{{ inp.name }} = 0.0{{ type_suffix }};
{% endfor %}
{% for out in model.outputs %}
    {{ name }}_Y.{{ out.name }} = 0.0{{ type_suffix }};
{% endfor %}
{% for s in model.state %}
    {{ name }}_{{ s.name }} = {{ s.initial_value }}{{ type_suffix }};
{% endfor %}
}

/**
 * @brief Step function — called every {{ "%.1f" % (model.sample_time_s * 1000) }}ms
 *        ({{ "%.1f" % (1.0 / model.sample_time_s) }} Hz)
 *
 * @trace {{ meta.model_path }} → model (top-level)
 * @trace Inputs: {% for inp in model.inputs %}{{ inp.name }}{{ ", " if not loop.last }}{% endfor %}

 * @trace Outputs: {% for out in model.outputs %}{{ out.name }}{{ ", " if not loop.last }}{% endfor %}

 * @trace Platform: {{ platform.name }} — real_T={{ real_T }}
 */
void {{ step_function }}(void)
{
{% for inp in model.inputs %}
    const real_T {{ inp.name }} = {{ name }}_U.{{ inp.name }};
{% endfor %}

{% for block in blocks %}
{% if block.type == "basis_function_sum" %}
    /* --- {{ block.name | capitalize }}: {{ block.description }} ---
     * @trace {{ meta.model_path }} → blocks.{{ block.name }}
     * @trace {{ block.equation_ref }}
     */
    real_T {{ block.name }}_term = 0.0{{ type_suffix }};
{% if block.unroll %}
{% for i in range(block.params.num_basis_functions) %}
    {{ block.name }}_term += {{ name }}_{{ block.name }}_coeffs[{{ i }}]
        * {{ block.name }}_phi({{ name }}_{{ block.params.basis_input }}, {{ i }},
            {{ name }}_{{ block.name }}_knots, {{ block.params.num_basis_functions }})
        * {{ block.params.input_signal }};
{% endfor %}
{% else %}
    {
        int32_T i;
        for (i = 0; i < {{ block.params.num_basis_functions }}; i++) {
            {{ block.name }}_term += {{ name }}_{{ block.name }}_coeffs[i]
                * {{ block.name }}_phi({{ name }}_{{ block.params.basis_input }}, i,
                    {{ name }}_{{ block.name }}_knots, {{ block.params.num_basis_functions }})
                * {{ block.params.input_signal }};
        }
    }
{% endif %}

{% elif block.type == "pid" %}
    /* --- PID Controller ---
     * @trace {{ meta.model_path }} → blocks.{{ block.name }}
     */
    real_T {{ block.name }}_output = {{ block.name }}_compute(
        {{ name }}_U.{{ model.inputs[0].name }},
        {{ name }}_U.{{ model.inputs[1].name }},
        {{ "%.4f" % model.sample_time_s }}{{ type_suffix }}
    );

{% elif block.type == "lookup_table" %}
    /* --- Lookup table: {{ block.description }} ---
     * @trace {{ meta.model_path }} → blocks.{{ block.name }}
     * @trace {{ block.equation_ref | default("") }}
     */
    real_T {{ block.name }}_term = {{ block.name }}_interpolate(
        {{ name }}_U.{{ block.params.input_signal }}
    );

{% elif block.type == "offset" %}
    /* --- Offset: {{ block.description }} ---
     * @trace {{ meta.model_path }} → blocks.{{ block.name }}
     */
    real_T {{ block.name }}_term = {{ block.params.coefficient }}{{ type_suffix }}
        * {{ name }}_{{ block.params.input_signal }};

{% endif %}
{% endfor %}
    /* --- Compute output --- */
{% set ns = namespace(terms=[]) %}
{% for block in blocks %}
{% if block.type == "basis_function_sum" or block.type == "offset" or block.type == "lookup_table" %}
{% set ns.terms = ns.terms + [block.name + "_term"] %}
{% elif block.type == "pid" %}
{% set ns.terms = ns.terms + [block.name + "_output"] %}
{% endif %}
{% endfor %}
    {{ name }}_Y.{{ model.outputs[0].name }} = {{ ns.terms | join("\n        + ") }};

{% for s in model.state %}
{% if s.name == "Paw_prev" %}
    /* Update autoregressive state */
    {{ name }}_{{ s.name }} = {{ name }}_Y.{{ model.outputs[0].name }};
{% endif %}
{% endfor %}
}

/**
 * @brief Terminate the {{ name }} controller.
 *
 * @trace {{ meta.model_path }} → model (termination)
 */
void {{ terminate_function }}(void)
{
    /* No dynamic resources to free — static allocation only */
}
