#include "{{ name }}_controller_types.h"

{% for block in blocks %}
{% if block.type == "basis_function_sum" %}
/* {{ block.description }}
 * @trace {{ meta.model_path }} → blocks.{{ block.name }}
 * @trace {{ block.equation_ref }}
 */
const real_T {{ name }}_{{ block.name }}_coeffs[{{ block.params.num_basis_functions }}] = {
{% for c in block.params.coefficients %}
    {{ "%.4f" % c }}{{ type_suffix }}{{ "," if not loop.last }}  /* {{ block.name }}[{{ loop.index0 }}] */
{% endfor %}
};

const real_T {{ name }}_{{ block.name }}_knots[{{ block.params.num_basis_functions + 1 }}] = {
{% for k in block.params.knots %}
    {{ "%.1f" % k }}{{ type_suffix }}{{ "," if not loop.last }}
{% endfor %}
};

{% elif block.type == "lookup_table" %}
/* {{ block.description }}
 * @trace {{ meta.model_path }} → blocks.{{ block.name }}
 * @trace {{ block.equation_ref | default("") }}
 */
const real_T {{ name }}_{{ block.name }}_bp[{{ block.params.breakpoints | length }}] = {
{% for bp in block.params.breakpoints %}
    {{ "%.4f" % bp }}{{ type_suffix }}{{ "," if not loop.last }}  /* bp[{{ loop.index0 }}] */
{% endfor %}
};

const real_T {{ name }}_{{ block.name }}_td[{{ block.params.breakpoints | length }}] = {
{% for td in block.params.table_data %}
    {{ "%.4f" % td }}{{ type_suffix }}{{ "," if not loop.last }}  /* td[{{ loop.index0 }}] */
{% endfor %}
};

{% endif %}
{% endfor %}
